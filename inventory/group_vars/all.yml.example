---
# ==========================================================
# AWS SSO / IAM Configuration
# ==========================================================
aws_profile: "YourSSOProfile"
aws_region: "us-east-1"

# ==========================================================
# AWS SSM SECRET LOOKUPS
# ==========================================================

# --- Core System ---
truenas_admin_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/truenas/admin_password',     profile=aws_profile, region=aws_region) }}"
admin_password:         "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/admin_password',      profile=aws_profile, region=aws_region) }}"
admin_public_key:       "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/public_key',          profile=aws_profile, region=aws_region) }}"
ansible_public_key:     "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/ansible_public_key',  profile=aws_profile, region=aws_region) }}"
zfs_encryption_key:     "{{ lookup('amazon.aws.ssm_parameter', '/storage/truenas/zfs_key',          profile=aws_profile, region=aws_region) }}"

# --- S3 & Cloud Sync ---
aws_access_key:     "{{ lookup('amazon.aws.ssm_parameter', '/storage/truenas/backups/s3_access_key',          profile=aws_profile, region=aws_region) }}"
aws_secret_key:     "{{ lookup('amazon.aws.ssm_parameter', '/storage/truenas/backups/s3_secret_key',          profile=aws_profile, region=aws_region) }}"
cloudsync_password: "{{ lookup('amazon.aws.ssm_parameter', '/storage/truenas/backups/cloudsync_password',     profile=aws_profile, region=aws_region) }}"
cloudsync_salt:     "{{ lookup('amazon.aws.ssm_parameter', '/storage/truenas/backups/cloudsync_salt',         profile=aws_profile, region=aws_region) }}"

# --- SMTP ---
smtp_user: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/smtp/user', profile=aws_profile, region=aws_region) }}"
smtp_pass: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/smtp/pass', profile=aws_profile, region=aws_region) }}"

# ==========================================================
# S3 Bucket Details
# ==========================================================
s3_bucket_name: "your-s3-bucket-name"
s3_endpoint: "s3.amazonaws.com"
s3_region: "{{ aws_region }}"

aws_s3_storage_class: "DEEP_ARCHIVE"

# ==========================================================
# Authentik LDAP
# ==========================================================
# svc-01 IP where the authentik-ldap outpost container listens on port 636.
svc_ldap_host: "192.168.20.20"

# Authentik LDAP base DN (matches the outpost's configured base DN).
truenas_ldap_basedn: "dc=ldap,dc=goauthentik,dc=io"

# Bind DN for the TrueNAS LDAP service account created by the ldap blueprint.
truenas_ldap_binddn: "cn=truenas-ldap-svc,ou=users,dc=ldap,dc=goauthentik,dc=io"

# Bind password — auto-generated by infra-playbook's svc.yml on first run.
# Run svc.yml at least once before truenas site.yml.
ldap_bind_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/svc/ldap/bind_password', profile=aws_profile, region=aws_region) }}"

# ==========================================================
# System Settings
# ==========================================================
base_domain: "example.com"           # all service FQDNs and emails derive from this

truenas_hostname: "your-nas-hostname"
truenas_admin_user: "your-admin-username"
truenas_domain: "infra.{{ base_domain }}"
truenas_ssh_port: 2222

# --- Ansible service account ---
ansible_service_user: ansible

# ==========================================================
# Trusted Networks
# ==========================================================
trusted_networks:
  - "192.168.x.x/24"                 # management network
  - "10.x.x.x/24"                    # VPN management plane

server_networks:
  - "192.168.x.x/24"                 # allowed to mount NFS shares

# ==========================================================
# Email Alerts
# ==========================================================
smtp_server: "email-smtp.{{ aws_region }}.amazonaws.com"
smtp_port: 587
smtp_security: "TLS"
from_email: "alerts@{{ base_domain }}"
alert_email: "admin@{{ base_domain }}"

# ==========================================================
# Storage Pool (RAID 10)
# ==========================================================
pool_name: "tank"
vdev_mirror_1: ["sda", "sdb"]
vdev_mirror_2: ["sdc", "sdd"]

# ==========================================================
# Datasets
#
# share_type: smb | nfs
# acltype:    POSIX | NFSV4  (optional — defaults to NFSV4 for smb, POSIX for nfs)
#             NFSV4 is required for SMB shares — enables Windows ACL inheritance
#             and correct permission display on macOS/iOS/Linux SMB clients.
#             POSIX is suitable for NFS-only shares.
# nfs_map:    mapall | maproot  (nfs only)
# ==========================================================
datasets:
  - name: "personal"
    recordsize: "128K"
    quota: "500G"
    owner: "{{ truenas_admin_user }}"
    group: "{{ truenas_admin_user }}"
    share_type: "smb"
    acltype: "NFSV4"
  - name: "dataset-01"
    recordsize: "128K"
    quota: "1TB"
    owner: "service_user"
    group: "service_group"
    share_type: "nfs"
    nfs_map: "maproot"

# ==========================================================
# Users & Groups
# ==========================================================
service_groups:
  - { name: "service_group", gid: 3000 }    # UIDs/GIDs must match NFS clients

service_users:
  - { name: "service_user", uid: 3000, group: "service_group", comment: "Service Account" }
